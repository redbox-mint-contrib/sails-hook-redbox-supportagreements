<div class="row admin-layout">
    <div class="col-md-3 col-lg-2">
        <%- include('layout/sidebar.ejs') %>
    </div>
    <div class="col-md-9 col-lg-10 admin-main-content">
        <h2>
            <%= TranslationService.t('support-agreement-title') %>
        </h2>

        <div class="row" style="margin-bottom: 20px;">
            <div class="col-md-12">
                <form method="GET" id="yearSelectorForm">
                    <div class="form-group">
                        <label for="yearSelector" class="control-label">
                            <%= TranslationService.t('select-year') %>:
                        </label>
                        <select id="yearSelector" name="year" class="form-control" style="display: inline-block; width: auto; margin-left: 10px;" onchange="this.form.submit()">
                            <% availableYears.forEach(function(year) { %>
                                <option value="<%= year %>" <%= year === selectedYear ? 'selected' : '' %>>
                                    <%= year %><%= year === currentYear ? ' (' + TranslationService.t('current-year') + ')' : '' %>
                                </option>
                            <% }); %>
                        </select>
                    </div>
                </form>
            </div>
        </div>

        <div class="panel panel-default">
            <div class="panel-heading">
                <span class="panel-title">
                    <%= TranslationService.t('support-agreement-details') %> - <%= selectedYear %>
                </span>
            </div>
            <div class="panel-body">
                <% if (canManageSupportAgreements) { %>
                    <form method="POST" action="/<%= branding %>/<%= portal %>/admin/supportAgreement/year" class="form-horizontal" style="margin-bottom: 20px;">
                        <input type="hidden" name="_csrf" value="<%= typeof _csrf !== 'undefined' ? _csrf : '' %>">
                        <input type="hidden" name="year" value="<%= selectedYear %>">
                        <div class="form-group">
                            <label for="agreedSupportDays" class="col-sm-3 control-label">
                                <%= TranslationService.t('agreed-support-days') %>
                            </label>
                            <div class="col-sm-3">
                                <input id="agreedSupportDays" name="agreedSupportDays" type="number" min="0" step="0.01" class="form-control" value="<%= agreedSupportDays %>">
                            </div>
                            <label for="usedSupportDays" class="col-sm-3 control-label">
                                <%= TranslationService.t('used-support-days') %>
                            </label>
                            <div class="col-sm-3">
                                <input id="usedSupportDays" name="usedSupportDays" type="number" min="0" step="0.01" class="form-control" value="<%= usedSupportDays %>">
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="col-sm-12 text-right">
                                <button type="submit" class="btn btn-primary">Save support year</button>
                            </div>
                        </div>
                    </form>

                    <form method="POST" action="/<%= branding %>/<%= portal %>/admin/supportAgreement/year/delete" class="text-right" style="margin-bottom: 20px;">
                        <input type="hidden" name="_csrf" value="<%= typeof _csrf !== 'undefined' ? _csrf : '' %>">
                        <input type="hidden" name="year" value="<%= selectedYear %>">
                        <button type="submit" class="btn btn-danger">Delete support year</button>
                    </form>
                <% } %>

                <div class="row">
                    <div class="col-md-6">
                        <div class="well">
                            <h4>
                                <%= TranslationService.t('agreed-support-days') %>
                            </h4>
                            <p class="lead text-info">
                                <%= agreedSupportDays %> days
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="well">
                            <h4>
                                <%= TranslationService.t('used-support-days') %>
                            </h4>
                            <p class="lead text-warning">
                                <%= usedSupportDays %> days
                            </p>
                        </div>
                    </div>
                </div>

                <%
                    var remainingDays = Math.max(0, agreedSupportDays - usedSupportDays);
                    var percentage = agreedSupportDays > 0 ? (remainingDays / agreedSupportDays) * 100 : 0;
                    var progressClass = percentage > 50 ? 'progress-bar-success' :
                        percentage > 20 ? 'progress-bar-warning' : 'progress-bar-danger';
                %>
                <div class="row">
                    <div class="col-md-12">
                        <p class="text-muted">
                            <% if (agreedSupportDays > 0) { %>
                                <%= TranslationService.t('remaining-support-days') %>: <strong>
                                    <%= remainingDays %>
                                </strong> days
                            <% } else { %>
                                <%= TranslationService.t('no-agreement-configured') %>
                            <% } %>
                        </p>
                        <div class="progress">
                            <div class="progress-bar <%= progressClass %>" role="progressbar"
                                aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"
                                style="width: <%= percentage.toFixed(1) %>%">
                                <%= Math.round(percentage) %>% available
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info" role="alert">
                    <strong>
                        <%= TranslationService.t('note') %>:
                    </strong>
                    <%= TranslationService.t('support-agreement-note') %>
                </div>
            </div>
        </div>

        <div class="panel panel-default">
            <div class="panel-heading">
                <span class="panel-title">
                    <%= (typeof TranslationService !== 'undefined' && TranslationService.t) ? TranslationService.t('release-notes-title') : 'Release notes' %>
                </span>
            </div>
            <div class="panel-body">
                <% if (canManageSupportAgreements) { %>
                    <form method="POST" action="/<%= branding %>/<%= portal %>/admin/supportAgreement/release-note" class="form-horizontal" style="margin-bottom: 30px;">
                        <input type="hidden" name="_csrf" value="<%= typeof _csrf !== 'undefined' ? _csrf : '' %>">
                        <input type="hidden" name="year" value="<%= selectedYear %>">
                        <div class="form-group">
                            <label for="newReleaseNoteTitle" class="col-sm-2 control-label">Title</label>
                            <div class="col-sm-10">
                                <input id="newReleaseNoteTitle" name="title" type="text" class="form-control" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="newReleaseNoteDate" class="col-sm-2 control-label">Release date</label>
                            <div class="col-sm-4">
                                <input id="newReleaseNoteDate" name="releaseDate" type="date" class="form-control">
                            </div>
                            <div class="col-sm-6 checkbox" style="padding-top: 0;">
                                <label>
                                    <input name="published" type="checkbox" value="true"> Published
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="newReleaseNoteBody" class="col-sm-2 control-label">Body</label>
                            <div class="col-sm-10">
                                <textarea id="newReleaseNoteBody" name="body" rows="4" class="form-control"></textarea>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="col-sm-12 text-right">
                                <button type="submit" class="btn btn-primary">Create release note</button>
                            </div>
                        </div>
                    </form>
                <% } %>

                <% if (!releaseNotes || releaseNotes.length === 0) { %>
                    <p class="text-muted">
                        <%= (typeof TranslationService !== 'undefined' && TranslationService.t) ? TranslationService.t('no-release-notes-configured') : 'No release notes configured.' %>
                    </p>
                <% } else { %>
                    <% releaseNotes.forEach(function(note) { %>
                        <div class="well">
                            <% if (canManageSupportAgreements) { %>
                                <form method="POST" action="/<%= branding %>/<%= portal %>/admin/supportAgreement/release-note/update" class="form-horizontal">
                                    <input type="hidden" name="_csrf" value="<%= typeof _csrf !== 'undefined' ? _csrf : '' %>">
                                    <input type="hidden" name="year" value="<%= selectedYear %>">
                                    <input type="hidden" name="id" value="<%= note.id %>">
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">Title</label>
                                        <div class="col-sm-10">
                                            <input name="title" type="text" class="form-control" value="<%= note.title %>" required>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">Release date</label>
                                        <div class="col-sm-4">
                                            <input name="releaseDate" type="date" class="form-control" value="<%= note.releaseDate || '' %>">
                                        </div>
                                        <div class="col-sm-6 checkbox" style="padding-top: 0;">
                                            <label>
                                                <input name="published" type="checkbox" value="true" <%= note.published ? 'checked' : '' %>> Published
                                            </label>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">Body</label>
                                        <div class="col-sm-10">
                                            <textarea name="body" rows="4" class="form-control"><%= note.body %></textarea>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <div class="col-sm-12 text-right">
                                            <button type="submit" class="btn btn-default">Update release note</button>
                                        </div>
                                    </div>
                                </form>
                                <form method="POST" action="/<%= branding %>/<%= portal %>/admin/supportAgreement/release-note/delete" class="text-right" style="margin-top: 10px;">
                                    <input type="hidden" name="_csrf" value="<%= typeof _csrf !== 'undefined' ? _csrf : '' %>">
                                    <input type="hidden" name="year" value="<%= selectedYear %>">
                                    <input type="hidden" name="id" value="<%= note.id %>">
                                    <button type="submit" class="btn btn-danger">Delete release note</button>
                                </form>
                            <% } else { %>
                                <h4><%= note.title %></h4>
                                <% if (note.releaseDate) { %>
                                    <p class="text-muted"><%= note.releaseDate %></p>
                                <% } %>
                                <p><%- note.renderedBody %></p>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>
</div>
