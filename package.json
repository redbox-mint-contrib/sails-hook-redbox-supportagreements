{
  "name": "@researchdatabox/sails-hook-redbox-supportagreements",
  "version": "1.0.0",
  "description": "ReDBox hook for support agreement administration",
  "main": "dist/index.js",
  "files": [
    "dist",
    "views",
    "README.md"
  ],
  "sails": {
    "isHook": true,
    "hasModels": true,
    "hasServices": true,
    "hasControllers": true,
    "hasWebserviceControllers": true,
    "hasConfig": true
  },
  "scripts": {
    "compile": "node ./node_modules/@researchdatabox/redbox-dev-tools/bin/run-hook-tsc.js -p tsconfig.json",
    "prepack": "npm run compile",
    "test": "npm run test:unit",
    "test:unit": "npm run compile && TS_NODE_PROJECT=./test/tsconfig.json node ./node_modules/@researchdatabox/redbox-dev-tools/bin/run-hook-mocha.js --config ./test/unit/.mocharc.cjs ./test/unit",
    "dev:run": "docker compose -f ./support/development/docker-compose.yml up --build --menu=false --abort-on-container-exit --exit-code-from rbportal",
    "dev:run:build": "docker compose -f ./support/development/docker-compose.yml build",
    "dev:run:clean": "docker compose -f ./support/development/docker-compose.yml down -v --remove-orphans --timeout 180"
  },
  "keywords": [
    "sails",
    "hook",
    "redbox"
  ],
  "license": "GPL-3.0",
  "dependencies": {},
  "peerDependencies": {
    "@researchdatabox/redbox-core": "0.0.1-beta.9022"
  },
  "devDependencies": {
    "@researchdatabox/redbox-core": "0.0.1-beta.9022",
    "@researchdatabox/redbox-dev-tools": "0.0.1-beta.9020",
    "@types/mocha": "10.0.10",
    "@types/node": "24.12.2",
    "@types/sinon": "21.0.0",
    "sinon": "21.0.2"
  }
}
